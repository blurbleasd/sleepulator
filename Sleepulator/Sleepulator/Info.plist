<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<!-- ATS justification (for App Review): users add arbitrary podcast RSS feeds, and a
	     large share of episode enclosures are still served over cleartext http://. This is
	     scoped to MEDIA only (AVPlayer audio) — NOT NSAllowsArbitraryLoads — so app API/web
	     traffic still requires HTTPS. Host-allowlisting isn't feasible for user-supplied feeds. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoadsInMedia</key>
		<true/>
	</dict>
</dict>
</plist>
